---
import '../styles/global.css';
export interface Props { title?: string }
const { title = 'TIRS' } = Astro.props as Props
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
