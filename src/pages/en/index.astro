---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/starwind/button/Button.astro';
import { t } from '@/lib/i18n';

const locale = 'en';
const text = t(locale);
---

<PageLayout title={text.homeTitle} locale={locale}>
  <h1>{text.homeHeading}</h1>
  <p>{text.homeIntro}</p>
  <Button href="/en/lessons/intro" class="w-fit">{text.viewSampleLesson}</Button>
  <h2>{text.availableLessons}</h2>
  <ul>
    <li><a href="/en/lessons/intro">{text.lessonIntro}</a></li>
    <li><a href="/en/lessons/history-of-astronomy-1">{text.lessonHistory1}</a></li>
    <li><a href="/en/lessons/history-of-astronomy-2">{text.lessonHistory2}</a></li>
  </ul>
</PageLayout>
